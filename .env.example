# Required: Postgres connection string (Railway's Postgres plugin provides this)
DATABASE_URL=postgres://user:password@localhost:5432/job_radar

# Optional: port to listen on (Railway sets this automatically)
PORT=3000

# Optional: if set, POST /mcp requires "Authorization: Bearer <token>"
# MCP_AUTH_TOKEN=change-me

# Optional: how many boards to fetch in parallel during a registry scan (default 16)
# FETCH_CONCURRENCY=16

# Optional: per-board request timeout in ms (default 8000). Very large boards
# (e.g. SpaceX, ~2MB) can exceed 8s on a slow day; raise this to include them.
# REQUEST_TIMEOUT_MS=8000
